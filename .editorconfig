# https://editorconfig.org — the formatting substrate, kept consistent across editors.
# ruff (pyproject.toml) is the arbiter for Python style; this only fixes charset, EOL, and
# indentation so diffs stay clean across machines and the Windows CI runner can't sneak in
# CRLF (which would break a path/diff assertion).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 120

[*.{toml,yml,yaml,json,jsonc,md,mdx,astro,js,mjs,cjs,ts,css}]
indent_size = 2

[*.md]
# Two trailing spaces are a hard line break in Markdown — don't strip them.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
