---
// Interactive playground: loads Pyodide (CPython in WASM), drops the REAL shipped
// ratchet.py + glue.py into its virtual FS, and runs the engine against a DiffFacts
// built from the mini-diff editor — no git, no server, the actual engine judging in
// the browser. The same glue is unit-tested under local python3.
//
// Each editor is a transparent <textarea> over a highlighted <pre> mirror (kept in
// sync on input + scroll), so you type plain text but see it syntax-highlighted. The
// whole widget is a fixed-dark console in both light and dark themes, like the hero.
const base = import.meta.env.BASE_URL;
---

<div class="pg" data-base={base}>
  <div class="pg-grid">
    <div class="pg-pane">
      <label class="pg-h" for="pg-toml">ratchet.toml <span>— your policy</span></label>
      <div class="pg-ed">
        <pre class="pg-hl" aria-hidden="true"><code data-hl="pg-toml"></code></pre>
        <textarea id="pg-toml" class="pg-edit" data-lang="toml" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off"></textarea>
      </div>
    </div>
    <div class="pg-pane">
      <label class="pg-h" for="pg-scen">change <span>— what the agent did</span></label>
      <div class="pg-ed">
        <pre class="pg-hl" aria-hidden="true"><code data-hl="pg-scen"></code></pre>
        <textarea id="pg-scen" class="pg-edit" data-lang="diff" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off"></textarea>
      </div>
      <p class="pg-legend"><code>A/M/D path</code> file · <code>+ line</code> added · <code>- line</code> removed · <code>$ cmd</code> command · <code>@ branch</code> · <code>write&gt; path</code> · <code>commit&gt; msg</code></p>
    </div>
  </div>
  <div class="pg-controls">
    <span class="pg-presets">try:</span>
    <button class="pg-preset" data-preset="strip">strip an assert</button>
    <button class="pg-preset" data-preset="delete">delete the test</button>
    <button class="pg-preset" data-preset="main">commit to main</button>
    <button class="pg-preset" data-preset="scope">scope creep</button>
    <button class="pg-preset" data-preset="floor">lower coverage</button>
    <button class="pg-preset" data-preset="protect">edit the gate</button>
    <button class="pg-preset" data-preset="invalid">an un-blockable rule</button>
    <button class="pg-run" data-run>▶ run ratchet</button>
  </div>
  <div class="pg-out" data-out aria-live="polite"><div class="pg-boot">booting the real engine in your browser…</div></div>
</div>

<style>
  /* A self-contained dark console — fixed palette so it reads the same in light
     and dark themes (like an embedded editor), instead of fighting Starlight's
     theme tokens. */
  .pg {
    --c-bg: #0d1117;
    --c-bg2: #161b22;
    --c-bd: #283039;
    --c-fg: #c9d1d9;
    --c-dim: #8b949e;
    --c-key: #79c0ff;
    --c-str: #a5d6ff;
    --c-num: #d2a8ff;
    --c-bool: #ff7b72;
    --c-sec: #ffa657;
    --c-add: #7ee787;
    --c-del: #ffa198;
    --c-cmd: #79c0ff;
    --c-br: #e3b341;
    --c-meta: #d2a8ff;
    --c-accent: #2f81f7;
    overflow: hidden;
    border: 1px solid var(--c-bd);
    border-radius: 12px;
    background: var(--c-bg);
    color: var(--c-fg);
    font-family: var(--__sl-font-mono, ui-monospace, "SF Mono", Menlo, monospace);
  }
  .pg-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--c-bd);
  }
  @media (max-width: 640px) {
    .pg-grid { grid-template-columns: 1fr; }
  }
  .pg-pane { display: flex; flex-direction: column; background: var(--c-bg); }
  .pg-h { padding: 9px 12px 6px; color: var(--c-fg); font-size: 12px; font-weight: 600; }
  .pg-h span { color: var(--c-dim); font-weight: 400; }

  /* The editor stack: highlighted <pre> behind a transparent <textarea>.
     Both layers MUST share every metric so the glyphs land on top of each other. */
  .pg-ed { position: relative; display: block; flex: 1; }
  /* The two layers MUST share every box metric so glyphs land on top of each
     other. The editor auto-grows to its content (JS sets height = scrollHeight),
     so it never scrolls internally — that's what kept the scrollbar-less mirror
     and the scrollbar-reserving textarea wrapping at different widths. */
  .pg-edit,
  .pg-hl {
    box-sizing: border-box;
    margin: 0;
    padding: 4px 12px 12px;
    border: 0;
    font: inherit;
    font-size: 13px;
    line-height: 1.55;
    tab-size: 2;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
    /* Pin text inflation on BOTH layers: iOS can auto-inflate a <textarea> and a
       <pre> by different ratios on rotation, which would desync the glyphs even
       though every other metric matches. */
    -webkit-text-size-adjust: 100%;
    text-size-adjust: 100%;
  }
  .pg-edit {
    display: block;
    width: 100%;
    /* No max-height: capping the height makes the textarea scroll internally,
       which reserves a scrollbar gutter the gutterless mirror doesn't — and the
       two layers wrap at different widths again (the exact bug this auto-grow
       fixes). If a cap is ever needed, reserve the gutter on BOTH layers. */
    min-height: 7em;
    height: auto;
    resize: none;
    outline: 0;
    overflow: hidden;
    background: transparent;
    color: transparent;
    caret-color: var(--c-fg);
  }
  .pg-hl {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    color: var(--c-fg);
  }
  .pg-hl code { font: inherit; }

  /* token colors */
  .t-cm, .d-cm { color: var(--c-dim); font-style: italic; }
  .t-sec { color: var(--c-sec); font-weight: 600; }
  .t-key { color: var(--c-key); }
  .t-str { color: var(--c-str); }
  .t-num { color: var(--c-num); }
  .t-bool { color: var(--c-bool); }
  .t-pun { color: var(--c-dim); }
  .d-A { color: var(--c-add); } .d-M { color: var(--c-br); } .d-D { color: var(--c-del); }
  .d-add { color: var(--c-add); } .d-del { color: var(--c-del); }
  .d-cmd { color: var(--c-cmd); } .d-br { color: var(--c-br); } .d-meta { color: var(--c-meta); }

  .pg-legend { margin: 0; padding: 7px 12px; border-top: 1px solid var(--c-bd); color: var(--c-dim); font-size: 11px; }
  .pg-legend code { background: var(--c-bg2); color: var(--c-fg); font-size: 11px; padding: 1px 4px; border-radius: 4px; }

  .pg-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    padding: 11px 12px;
    border-top: 1px solid var(--c-bd);
    background: var(--c-bg2);
  }
  .pg-presets { color: var(--c-dim); font-size: 13px; }
  .pg-preset {
    padding: 4px 11px;
    border: 1px solid var(--c-bd);
    border-radius: 999px;
    background: var(--c-bg);
    color: var(--c-fg);
    font-size: 12.5px;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .pg-preset:hover { border-color: var(--c-accent); color: #fff; }
  .pg-run {
    margin-left: auto;
    padding: 6px 16px;
    border: 1px solid var(--c-accent);
    border-radius: 8px;
    background: var(--c-accent);
    color: #fff;
    font-size: 13.5px;
    font-weight: 600;
    cursor: pointer;
  }
  .pg-run[disabled] { opacity: 0.55; cursor: progress; }

  .pg-out {
    padding: 14px;
    min-height: 84px;
    border-top: 1px solid var(--c-bd);
    font-size: 13px;
    line-height: 1.5;
  }
  .pg-boot { color: var(--c-dim); }
  .pg-boot::before { content: "⏳ "; }
  .pg-status { display: inline-block; margin-bottom: 10px; padding: 3px 10px; border-radius: 7px; font-weight: 700; }
  .pg-status.bad { background: #2a1014; color: #ff7a85; border: 1px solid #5b2026; }
  .pg-status.good { background: #0e2417; color: #4ade80; border: 1px solid #1f5236; }
  .pg-group { margin: 12px 0 4px; color: var(--c-dim); font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; }
  .pg-f { margin: 3px 0; }
  .pg-f .tag { margin-right: 7px; font-weight: 700; }
  .pg-f.block .tag { color: var(--c-del); } .pg-f.warn .tag { color: var(--c-br); }
  .pg-f .id { color: var(--c-fg); } .pg-f .why { color: var(--c-dim); }
  .pg-err { color: var(--c-del); white-space: pre-wrap; }
</style>

<script>
  // ---- syntax highlighting (mirror layer) -------------------------------------
  const esc = (s: string) => s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' })[c]!);

  function hlValue(v: string): string {
    // Final `(.)` alternative guarantees EVERY character is emitted — incl. a lone
    // unbalanced quote while typing a string. A skipped char would shorten the
    // mirror and shift every following glyph out from under the caret.
    const re = /("(?:[^"\\]|\\.)*")|(\b(?:true|false)\b)|(-?\d+\.?\d*)|([[\],])|([^"\d[\]]+)|(.)/g;
    let out = '', m: RegExpExecArray | null;
    while ((m = re.exec(v))) {
      if (m[1]) out += `<span class="t-str">${esc(m[1])}</span>`;
      else if (m[2]) out += `<span class="t-bool">${esc(m[2])}</span>`;
      else if (m[3]) out += `<span class="t-num">${esc(m[3])}</span>`;
      else if (m[4]) out += `<span class="t-pun">${esc(m[4])}</span>`;
      else out += esc(m[0]);
    }
    return out;
  }

  function hlToml(src: string): string {
    return src.split('\n').map((line) => {
      // split off a trailing comment (a '#' outside any string)
      let inStr = false, ci = -1;
      for (let i = 0; i < line.length; i++) {
        const ch = line[i];
        if (ch === '"') inStr = !inStr;
        else if (ch === '#' && !inStr) { ci = i; break; }
      }
      const code = ci >= 0 ? line.slice(0, ci) : line;
      const comment = ci >= 0 ? `<span class="t-cm">${esc(line.slice(ci))}</span>` : '';
      const trimmed = code.trimStart();
      let body: string;
      if (/^\[\[?.*\]?\]\s*$/.test(trimmed)) {
        body = `<span class="t-sec">${esc(code)}</span>`;
      } else {
        const eq = code.indexOf('=');
        body = eq >= 0
          ? `<span class="t-key">${esc(code.slice(0, eq))}</span>=${hlValue(code.slice(eq + 1))}`
          : esc(code);
      }
      return body + comment;
    }).join('\n');
  }

  function hlDiff(src: string): string {
    return src.split('\n').map((line) => {
      const t = line.trimStart();
      const cls =
        /^[AMD]\s/.test(t) ? 'd-' + t[0] :
        t.startsWith('+') ? 'd-add' :
        t.startsWith('-') ? 'd-del' :
        t.startsWith('$') ? 'd-cmd' :
        t.startsWith('@') ? 'd-br' :
        /^(?:write|commit)>/.test(t) ? 'd-meta' :
        t.startsWith('#') ? 'd-cm' : '';
      return cls ? `<span class="${cls}">${esc(line)}</span>` : esc(line);
    }).join('\n');
  }

  // Grow the textarea to fit its content so it never scrolls internally.
  function fit(ta: HTMLTextAreaElement) {
    ta.style.height = 'auto';
    ta.style.height = ta.scrollHeight + 'px';
  }

  function paint(ta: HTMLTextAreaElement) {
    const code = ta.parentElement!.querySelector<HTMLElement>('.pg-hl code')!;
    const hl = ta.dataset.lang === 'toml' ? hlToml(ta.value) : hlDiff(ta.value);
    code.innerHTML = hl + '\n'; // trailing newline keeps the last line in view
    fit(ta);
  }

  // ---- the engine -------------------------------------------------------------
  const STARTER = `schema = 1
[repo]
default_branch = "main"
code = ["src/**/*.py"]
tests = ["tests/**/*.py"]

# only these paths may change — scope creep blocks (the #1 mined gap)
[[check]]
id = "scope-lock"
kind = "fact"
severity = "block"
primitive = "scope_lock"
allow = ["src/**", "tests/**", "docs/**", "*.md"]

# real-time (agent layer): if on main, branch first
[[check]]
id = "branch-first"
kind = "fact"
severity = "block"
layer = "agent"
primitive = "forbid_commit_on_branch"
branch = ["main"]

# don't delete the failing test (file D-status)
[[check]]
id = "no-test-delete"
kind = "fact"
severity = "block"
primitive = "forbid_delete"
scope = "tests"
unless_paired_add = true

# don't strip the assertion (the '-' twin of forbid_pattern)
[[check]]
id = "keep-asserts"
kind = "fact"
severity = "block"
primitive = "forbid_removal"
pattern = "assert"
scope = "tests"

# never leak a credential
[[check]]
id = "secret-scan"
kind = "fact"
severity = "block"
primitive = "secret_scan"

# the namesake ratchet: a lowered threshold is byte-identical to a raise to a
# one-side scanner — numeric_floor pairs the number across the −/+ hunks
[[check]]
id = "coverage-ratchet"
kind = "fact"
severity = "block"
primitive = "numeric_floor"
key = "fail_under\\\\s*=\\\\s*(\\\\d+)"
direction = "no_decrease"

# real-time (agent layer): can't edit the gate's own files in-session
[[check]]
id = "self-protect"
kind = "fact"
severity = "block"
layer = "agent"
primitive = "self_protect"
paths = ["ratchet.toml", ".github/workflows/**"]
`;

  const INVALID = `schema = 1
[repo]
default_branch = "main"

# This tries to HARD-BLOCK on a judgment (an LLM-judge the agent could sway).
# ratchet refuses to load it: severity="block" REQUIRES kind="fact".
[[check]]
id = "vibes-check"
kind = "advisory"
severity = "block"
primitive = "judge"
prompt = "is the code good?"
`;

  const PRESETS: Record<string, { toml: string; scen: string }> = {
    strip: { toml: STARTER, scen: 'M tests/test_auth.py\n-     assert token.valid()' },
    delete: { toml: STARTER, scen: 'D tests/test_auth.py' },
    main: { toml: STARTER, scen: '$ git commit -m wip\n@ main' },
    scope: { toml: STARTER, scen: 'M src/app.py\nM infra/deploy.tf' },
    floor: { toml: STARTER, scen: 'M pyproject.toml\n- fail_under = 85\n+ fail_under = 75' },
    protect: { toml: STARTER, scen: 'write> ratchet.toml' },
    invalid: { toml: INVALID, scen: '' },
  };

  const PYODIDE = 'https://cdn.jsdelivr.net/pyodide/v0.26.4/full/pyodide.js';
  let ready: Promise<any> | null = null;

  async function boot(base: string) {
    if (!(window as any).loadPyodide) {
      await new Promise<void>((res, rej) => {
        const s = document.createElement('script');
        s.src = PYODIDE;
        s.onload = () => res();
        s.onerror = () => rej(new Error('failed to load Pyodide'));
        document.head.appendChild(s);
      });
    }
    const pyodide = await (window as any).loadPyodide();
    const [eng, glue] = await Promise.all([
      fetch(base + 'ratchet.py').then((r) => r.text()),
      fetch(base + 'glue.py').then((r) => r.text()),
    ]);
    pyodide.FS.writeFile('ratchet.py', eng);
    pyodide.FS.writeFile('glue.py', glue);
    pyodide.runPython('import glue');
    return pyodide;
  }

  function render(out: HTMLElement, res: any) {
    if (!res.ok) {
      out.innerHTML = `<div class="pg-status bad">config invalid</div><div class="pg-err">${esc(res.error || '')}</div>`;
      return;
    }
    const denied = res.agent_denials.length > 0;
    const blocked = res.change_findings.some((f: any) => f.sev === 'block');
    const pill = denied || blocked ? 'bad' : 'good';
    let html = `<div class="pg-status ${pill}">${esc(res.summary)}</div>`;
    const row = (f: any) =>
      `<div class="pg-f ${f.sev}"><span class="tag">[${f.sev === 'block' ? 'BLOCK' : 'warn'}]</span><span class="id">${esc(f.id)}</span> <span class="why">— ${esc(f.reason)}</span></div>`;
    if (res.agent_denials.length) {
      html += `<div class="pg-group">agent layer · denied in real time</div>${res.agent_denials.map(row).join('')}`;
    }
    if (res.change_findings.length) {
      html += `<div class="pg-group">change layer · pre-push + CI</div>${res.change_findings.map(row).join('')}`;
    }
    if (!res.agent_denials.length && !res.change_findings.length) {
      html += `<div class="pg-f"><span class="why">no findings — the change satisfies every rule.</span></div>`;
    }
    out.innerHTML = html;
  }

  function init() {
    const pg = document.querySelector<HTMLElement>('.pg');
    if (!pg) return;
    const base = pg.dataset.base || '/';
    const toml = pg.querySelector<HTMLTextAreaElement>('#pg-toml')!;
    const scen = pg.querySelector<HTMLTextAreaElement>('#pg-scen')!;
    const out = pg.querySelector<HTMLElement>('[data-out]')!;
    const runBtn = pg.querySelector<HTMLButtonElement>('[data-run]')!;

    for (const ta of [toml, scen]) {
      ta.addEventListener('input', () => paint(ta));
    }
    // Re-fit after a width change (rewrap changes height) and after fonts settle.
    // Coalesce into one rAF so a resize/rotation storm doesn't thrash layout (each
    // fit() forces a write→read→write; rotation fires resize continuously).
    let raf = 0;
    const refit = () => {
      if (raf) return;
      raf = requestAnimationFrame(() => { raf = 0; fit(toml); fit(scen); });
    };
    window.addEventListener('resize', refit);
    window.addEventListener('load', refit);
    const setVal = (ta: HTMLTextAreaElement, v: string) => { ta.value = v; paint(ta); };

    setVal(toml, PRESETS.strip.toml);
    setVal(scen, PRESETS.strip.scen);

    async function run() {
      runBtn.disabled = true;
      try {
        if (!ready) ready = boot(base);
        const pyodide = await ready;
        pyodide.globals.set('__toml', toml.value);
        pyodide.globals.set('__scen', scen.value);
        const res = JSON.parse(pyodide.runPython('glue.run_json(__toml, __scen)'));
        render(out, res);
      } catch (e) {
        out.innerHTML = `<div class="pg-status bad">engine failed to load</div><div class="pg-err">${esc(String(e))}\n\nPyodide needs WebAssembly + network access to the CDN.</div>`;
      } finally {
        runBtn.disabled = false;
      }
    }

    pg.querySelectorAll<HTMLButtonElement>('.pg-preset').forEach((b) =>
      b.addEventListener('click', () => {
        const p = PRESETS[b.dataset.preset!];
        setVal(toml, p.toml);
        setVal(scen, p.scen);
        run();
      })
    );
    runBtn.addEventListener('click', run);
    run(); // auto-run the default so the page shows a live verdict immediately
  }

  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
</script>
